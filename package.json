    "hyperframes": "^0.6.84",
    "next": "16.2.7",
    "node-cron": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.482",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
