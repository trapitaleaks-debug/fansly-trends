{
  "name": "fansly-trends",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "scrape": "ts-node --project scraper/tsconfig.json scraper/index.ts",
    "scrape:feet": "ts-node --project scraper/tsconfig.json scraper/feet.ts",
    "scrape:discover": "DISCOVERY=true ts-node --project scraper/tsconfig.json scraper/index.ts",
    "scrape:headed": "HEADLESS=false ts-node --project scraper/tsconfig.json scraper/index.ts",
    "velocity": "ts-node --project scraper/tsconfig.json scraper/velocity.ts",
    "pipeline:bootstrap": "ts-node --project pipeline/tsconfig.json pipeline/bootstrap/process-model.ts",
    "pipeline:server": "ts-node --project pipeline/tsconfig.json pipeline/server.ts",
    "pipeline:run": "ts-node --project pipeline/tsconfig.json pipeline/index.ts",
    "pipeline:watch": "ts-node --project pipeline/tsconfig.json pipeline/index.ts --watch",
    "pipeline:sheet": "ts-node --project pipeline/tsconfig.json pipeline/sheet.ts",
    "pipeline:post": "ts-node --project pipeline/tsconfig.json pipeline/post-approved.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:pipeline": "tsc --noEmit --project pipeline/tsconfig.json"
  },
  "dependencies": {
